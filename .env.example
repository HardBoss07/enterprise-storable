# --- Database Configuration ---
# Root password for MySQL setup (only used during container initialization)
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=storable

# Application credentials for the backend to connect to MySQL
DB_USER=backend_user
DB_PASS=backend_password

# JDBC URL for the backend (Update 'db' to 'localhost' if running outside Docker)
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/storable?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=${DB_USER}
SPRING_DATASOURCE_PASSWORD=${DB_PASS}

# --- Backend Configuration ---
SERVER_PORT=8080
MAX_FILE_SIZE=5GB
MAX_REQUEST_SIZE=5GB
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=none
STORABLE_STORAGE_UPLOAD_DIR=/app/storage

# --- Auth Configuration ---
STORABLE_AUTH_GUEST_USER_ID=00000000-0000-0000-0000-000000000000
STORABLE_AUTH_GUEST_MODE_ENABLED=true

# --- Frontend Configuration ---
# The URL where the Backend API is reachable from the Browser
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Docker & Infrastructure ---
# Port mapping for host access
HOST_PORT_BACKEND=8080
HOST_PORT_FRONTEND=3000
HOST_PORT_DB=3306
